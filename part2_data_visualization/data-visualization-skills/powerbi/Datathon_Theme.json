{
  "name": "VinDatathon 2026 - Executive Theme",
  "dataColors": [
    "#2F7D4B", 
    "#178F91", 
    "#3F6FA6", 
    "#7654A7", 
    "#D9842E", 
    "#B84848"
  ],
  "background": "#F7F8F4",
  "foreground": "#152018",
  "tableAccent": "#178F91",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F7F8F4" } },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "*": [
          {
            "color": { "solid": { "color": "#617067" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#D9DFD6" } },
            "radius": 4
          }
        ],
        "title": [
          {
            "fontColor": { "solid": { "color": "#152018" } },
            "fontSize": 11,
            "fontFamily": "DIN"
          }
        ]
      }
    }
  }
}